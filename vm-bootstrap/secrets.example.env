# Hestia VM Bootstrap - Secrets Template
# 複製此檔為 ~/secrets.env，填入真實值
# 重建時可直接 SCP 到 VM 的 ~/secrets.env，避免重複手動輸入

# LLM provider 的 API key（Groq 用 gsk_ 開頭的 key）
OPENAI_API_KEY=

# Provider endpoint（Groq：https://api.groq.com/openai/v1）
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# 固定填 custom（使用 OpenAI-compatible provider）
HERMES_INFERENCE_PROVIDER=custom

# 模型名稱（Groq：llama-3.3-70b-versatile）
HERMES_INFERENCE_MODEL=llama-3.3-70b-versatile

# OpenRouter key（fallback 用）
OPENROUTER_API_KEY=

# Telegram Bot token（@BotFather 取得）
TELEGRAM_BOT_TOKEN=

# 你的 Telegram User ID（用 @userinfobot 查，純數字）
TELEGRAM_ALLOWED_USERS=

# Google Gemini API key（fallback 用）
GEMINI_API_KEY=
